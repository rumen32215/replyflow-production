# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp Cloud API (Meta Embedded Signup + webhook)
# App ID and Config ID are not secret — Meta's JS SDK requires them
# client-side. App Secret and the webhook verify token must stay server-only.
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v20.0
NEXT_PUBLIC_WHATSAPP_APP_ID=
NEXT_PUBLIC_WHATSAPP_CONFIG_ID=

# AI (not wired yet — placeholder for Phase 5)
OPENAI_API_KEY=
