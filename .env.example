# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp Cloud API (Meta Embedded Signup + webhook)
# App ID and Config ID are not secret — Meta's JS SDK requires them
# client-side. App Secret and the webhook verify token must stay server-only.
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v20.0
NEXT_PUBLIC_WHATSAPP_APP_ID=
NEXT_PUBLIC_WHATSAPP_CONFIG_ID=

# AI — Reply Engine (Sprint 10A). LLM_PROVIDER selects the adapter in
# lib/reply-engine/llm/providers/ — "openai" is the only one implemented
# so far. OPENAI_MODEL_SMALL is used for the cheap Understanding Engine
# classification call, OPENAI_MODEL_LARGE for reply generation — both
# default to gpt-4o-mini if unset.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL_SMALL=gpt-4o-mini
OPENAI_MODEL_LARGE=gpt-4o-mini
